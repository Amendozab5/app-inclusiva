# Root .gitignore for app-inclusiva

# Backend ignores
backend/target/
backend/.mvn/wrapper/maven-wrapper.jar
backend/.apt_generated
backend/.classpath
backend/.factorypath
backend/.project
backend/.settings
backend/.springBeans
backend/.sts4-cache
backend/.idea
backend/*.iws
backend/*.iml
backend/*.ipr
backend/.vscode/

# Frontend ignores
frontend/node_modules/
frontend/dist/
frontend/tmp/
frontend/out-tsc/
frontend/bazel-out/
frontend/.angular/cache
frontend/.sass-cache/
frontend/coverage/
frontend/.idea/
frontend/.vscode/*
!frontend/.vscode/settings.json
!frontend/.vscode/tasks.json
!frontend/.vscode/launch.json
!frontend/.vscode/extensions.json
frontend/.history/*

# OS files
.DS_Store
Thumbs.db

# Misc
*.log
